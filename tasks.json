[
  {
    "label": "Global CMake: One-Click Build (Debug)",
    "command": "cmake -S . -B cmake-build-debug -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build cmake-build-debug",
    "use_new_terminal": false,
    "allow_concurrent_runs": false
  },
  {
    "label": "Global CMake: One-Click Build (Release)",
    "command": "cmake -S . -B cmake-build-release -DCMAKE_BUILD_TYPE=Release -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build cmake-build-release",
    "use_new_terminal": false,
    "allow_concurrent_runs": false
  }
]
